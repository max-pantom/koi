{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Koi",
  "version": "0.1.0",
  "identifier": "design.koi.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Koi",
        "width": 1280,
        "height": 900,
        "minWidth": 860,
        "minHeight": 560,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 18,
          "y": 18
        },
        "backgroundColor": "#ffffff",
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
