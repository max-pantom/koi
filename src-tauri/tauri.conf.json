{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Koi",
  "version": "0.1.0",
  "identifier": "design.koi.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Koi",
        "width": 1280,
        "height": 900,
        "minWidth": 860,
        "minHeight": 560,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 18,
          "y": 18
        },
        "backgroundColor": "#ffffff",
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "GraphicsAndDesign",
    "shortDescription": "A tiny local moodboard for folders.",
    "longDescription": "Koi is a local-first moodboard for browsing image folders, GIFs, palettes, and visual references without accounts or cloud sync.",
    "copyright": "Copyright © 2026 Koi",
    "macOS": {
      "bundleName": "Koi",
      "bundleVersion": "1",
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 420
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    }
  }
}
